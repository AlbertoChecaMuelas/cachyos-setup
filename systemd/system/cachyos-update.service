[Unit]
Description=Actualiza el sistema CachyOS (pacman + yay) y notifica
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
Environment=HOME=/home/@USER@
Environment=CACHYOS_SETUP_STATE_DIR=/var/lib/cachyos-setup
Environment=DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/@UID@/bus
Environment=CACHYOS_USER=@USER@
ExecStartPre=/usr/bin/nm-online -q --timeout=60
ExecStart=@SCRIPTS_DIR@/update-system.sh
